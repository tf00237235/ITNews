# Discord：在頻道 → 整合 → Webhook 建立一支，貼上整段 URL
DISCORD_WEBHOOK_URL=

# Telegram：和 @BotFather 申請 bot 拿 token；和 bot 對話一次後用
# https://api.telegram.org/bot<token>/getUpdates 找到 chat.id（個人或群組）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 設為 1 時只列印不真的推播，方便本機測試
DRY_RUN=0

# 一次最多推幾條（預設 20）
MAX_ITEMS=20

# 抓多少小時內的新文章（預設 36 小時，避開時區與排程延遲）
LOOKBACK_HOURS=36
